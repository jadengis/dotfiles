# Copy to worker.env in this directory and customize.
# If worker.env contains secrets (e.g. --api-key), use: chmod 600 ~/.config/cursor-agent/worker.env
# Optional extra arguments for: agent worker start
# CURSOR_WORKER_OPTS=--name "my-devbox"
# CURSOR_WORKER_OPTS=--worker-dir /path/to/repo
# For shared devboxes or automation (see Cursor service accounts docs):
# CURSOR_WORKER_OPTS=--api-key "your-api-key"
#
# Headless / SSH-only: user services stop when you have no login sessions unless linger is on:
#   loginctl enable-linger "$USER"
